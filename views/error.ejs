<% layout('layout/boilerplate') %>

<%
    var status = (err && err.status) || 500;
    var name = (err && err.name) || 'Error';
    var msg = (err && err.message) || 'Something went wrong';
    var isProd = process.env.NODE_ENV === 'production';
    var img = status === 404 ? '/stylesheets/page404.png' : '/stylesheets/error.png';
%>

<section style="padding: 32px 0 24px; text-align: center;">
    <div class="eyebrow eyebrow-accent" style="margin-bottom: 18px;">Halt</div>
    <img src="<%= img %>" alt="" style="max-width: 360px; width: 100%; height: auto; margin: 0 auto 24px; display: block;">
    <div class="h-display lg" style="color: var(--ink); font-size: 96px;"><%= status %></div>
    <h1 class="h-title" style="margin-top: 16px;"><%= msg %></h1>
    <p class="lede" style="margin: 12px auto 32px;">
        <% if (status === 404) { %>
            The page you were looking for has moved, been deleted, or never existed.
        <% } else { %>
            Something didn't go to plan on our side. Try again, or head back to the marketplace.
        <% } %>
    </p>
    <div class="row-flex" style="justify-content: center;">
        <button onclick="window.history.back()" class="btn btn-ghost">
            <i class="fa-solid fa-arrow-left" style="font-size: 11px;"></i>
            Go back
        </button>
        <a href="/home" class="btn btn-primary">
            Back to marketplace
            <i class="fa-solid fa-arrow-right arrow" style="font-size: 11px;"></i>
        </a>
    </div>
</section>

<% if (!isProd && err && err.stack) { %>
    <section style="margin-top: 56px;">
        <div class="eyebrow" style="margin-bottom: 12px;">Debug · development only</div>
        <div class="surface" style="padding: 0;">
            <div style="padding: 16px 20px; border-bottom: 1px solid var(--rule); display: flex; align-items: center; gap: 12px;">
                <span class="pill danger"><span class="pill-dot"></span><%= status %></span>
                <span class="mono" style="font-size: 13px;"><%= name %></span>
            </div>
            <pre class="mono" style="margin: 0; padding: 20px; font-size: 12px; line-height: 1.6; color: var(--ink-soft); white-space: pre-wrap; overflow-x: auto;"><%= err.stack %></pre>
        </div>
    </section>
<% } %>

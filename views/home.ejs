<% layout('layout/boilerplate') %>

<%
    function fmtINR(n) {
        if (n === undefined || n === null) return '—';
        return Number(n).toLocaleString('en-IN');
    }
    function initials(name) {
        if (!name) return '?';
        var parts = String(name).trim().split(/\s+/);
        if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
        return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
    }

    var titles = {
        '1':  ['Pending deals', 'Offers you posted that haven\'t been picked up yet.'],
        '-1': ['Closed deals',  'Deals that have matched a counterparty.'],
        '0':  ['Available to you', 'Open offers within your eligibility ceiling.']
    };
    var pendKey = String(isPend);
    var heading = titles[pendKey][0];
    var sub = titles[pendKey][1];

    var pendingCount = allLoans.filter(function (l) { return l.isPending; }).length;
    var closedCount  = allLoans.filter(function (l) { return !l.isPending; }).length;
%>

<div class="header-block" style="padding-bottom: 8px;">
    <div>
        <div class="eyebrow eyebrow-accent" style="margin-bottom: 10px;">
            <% if (isPend === 0) { %>Marketplace<% } else if (isPend === 1) { %>Your activity<% } else { %>Archive<% } %>
        </div>
        <h1 class="h-title"><%= heading %></h1>
        <p class="lede" style="margin-top: 8px;"><%= sub %></p>
    </div>

    <% if (currentUser && currentUser.max_amount && isPend === 0) { %>
        <div style="text-align: right;">
            <div class="eyebrow" style="margin-bottom: 6px;">Your ceiling</div>
            <div class="h-display md mono" style="font-style: italic;">
                <span style="font-family: var(--serif);">₹</span><%= fmtINR(currentUser.max_amount) %>
            </div>
            <div class="faint" style="font-size: 12px; margin-top: 4px;">
                CIBIL-equivalent <span class="mono"><%= currentUser.cibil || '—' %></span>
            </div>
        </div>
    <% } %>
</div>

<nav class="tabs" style="margin-top: 12px; margin-bottom: 40px;">
    <a href="/home" class="tab <%= isPend === 0 ? 'active' : '' %>">
        Available
    </a>
    <a href="/home?isPending=true" class="tab <%= isPend === 1 ? 'active' : '' %>">
        My deals
        <% if (isPend === 1) { %><span class="count"><%= allLoans.length %></span><% } %>
    </a>
    <a href="/home?isPending=false" class="tab <%= isPend === -1 ? 'active' : '' %>">
        Closed
        <% if (isPend === -1) { %><span class="count"><%= allLoans.length %></span><% } %>
    </a>
</nav>

<% if (allLoans.length === 0) { %>
    <div class="empty">
        <img src="/stylesheets/empty.svg" alt="" style="width: 200px; max-width: 60%; height: auto; margin: 0 auto 20px; display: block; opacity: 0.85;">
        <h2>
            <% if (isPend === 1) { %>No pending offers
            <% } else if (isPend === 0) { %>Nothing matches yet
            <% } else { %>No closed deals
            <% } %>
        </h2>
        <p>
            <% if (isPend === 0) { %>
                There aren't any open offers within your eligibility right now. Try posting one.
            <% } else if (isPend === 1) { %>
                Post a request or an offer and it will show up here while it waits for a match.
            <% } else { %>
                Once a deal matches a counterparty, you'll see the archive here.
            <% } %>
        </p>
        <a href="/loan/apply" class="btn btn-primary btn-lg">
            Post a deal
            <i class="fa-solid fa-arrow-right arrow" style="font-size: 12px;"></i>
        </a>
    </div>
<% } else { %>
    <section class="loan-list">
        <% for (let loan of allLoans) { %>
            <div class="loan-row">
                <div class="col col-amount" style="gap: 8px;">
                    <span class="label">Principal</span>
                    <div class="v">
                        <span style="font-family: var(--serif);">₹</span><%= fmtINR(loan.amount) %>
                    </div>
                    <div class="row-flex" style="gap: 8px;">
                        <% if (loan.category === 'provide') { %>
                            <span class="pill accent"><span class="pill-dot"></span>Offering</span>
                        <% } else { %>
                            <span class="pill info"><span class="pill-dot"></span>Requesting</span>
                        <% } %>
                        <% if (loan.isPending) { %>
                            <span class="pill warn"><span class="pill-dot"></span>Open</span>
                        <% } else { %>
                            <span class="pill"><span class="pill-dot"></span>Closed</span>
                        <% } %>
                    </div>
                </div>

                <div class="col">
                    <span class="label">Interest</span>
                    <span class="value mono"><%= loan.interest %>%</span>
                </div>

                <div class="col">
                    <span class="label">Tenure</span>
                    <span class="value mono"><%= loan.timePeriod %> yr</span>
                </div>

                <div class="col">
                    <span class="label">
                        <% if (!loan.isPending && loan.acceptedBy) { %>Counterparty<% } else { %>Posted by<% } %>
                    </span>
                    <div class="who">
                        <span class="avatar"><%= initials(!loan.isPending && loan.acceptedBy ? loan.acceptedBy.name : loan.owner.name) %></span>
                        <span class="value">
                            <%= !loan.isPending && loan.acceptedBy ? loan.acceptedBy.name : loan.owner.name %>
                        </span>
                    </div>
                </div>

                <div class="actions">
                    <% if (loan.isPending) { %>
                        <% if (loan.owner.id === currentUser.id) { %>
                            <a href="/loan/<%= loan.id %>/edit" class="btn btn-ghost btn-sm">
                                <i class="fa-solid fa-pen" style="font-size: 11px;"></i>
                                Edit
                            </a>
                            <form action="/loan/<%= loan.id %>/delete?_method=DELETE" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="fa-solid fa-trash" style="font-size: 11px;"></i>
                                    Delete
                                </button>
                            </form>
                        <% } else { %>
                            <a href="/loan/<%= loan.id %>/show" class="btn btn-ghost btn-sm">
                                Details
                            </a>
                            <form action="/loan/<%= loan.id %>/accept" method="post" style="display:inline;">
                                <button type="submit" class="btn btn-primary btn-sm">
                                    Accept
                                    <i class="fa-solid fa-arrow-right arrow" style="font-size: 10px;"></i>
                                </button>
                            </form>
                        <% } %>
                    <% } else { %>
                        <a href="/loan/<%= loan.id %>/show" class="btn btn-ghost btn-sm">
                            View record
                            <i class="fa-solid fa-arrow-right arrow" style="font-size: 10px;"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        <% } %>
    </section>
<% } %>

<% layout('layout/boilerplate') %>

<div class="header-block">
    <div>
        <div class="eyebrow eyebrow-accent" style="margin-bottom: 6px;">Profile</div>
        <h1 class="h-title">Edit your details</h1>
        <p class="lede" style="margin-top: 8px;">
            Identity and banking information. Used to compute eligibility and notify your counterparty when a deal closes.
        </p>
    </div>
    <a href="/profile" class="btn btn-ghost">
        <i class="fa-solid fa-arrow-left" style="font-size: 11px;"></i>
        Cancel
    </a>
</div>

<!-- Document tiles -->
<section style="margin: 32px 0 40px;">
    <div class="eyebrow" style="margin-bottom: 14px;">Documents</div>
    <div class="tile-grid">
        <button type="button" class="tile <%= user.aadharPic.length === 1 ? '' : 'missing' %>"
            data-bs-toggle="modal" data-bs-target="#aadharPicModal">
            <div>
                <div class="t-label">Aadhar card</div>
                <div class="t-value"><%= user.aadharPic.length === 1 ? 'On file' : 'Upload required' %></div>
            </div>
            <span class="t-mark"><%= user.aadharPic.length === 1 ? '✓' : '!' %></span>
        </button>

        <button type="button" class="tile <%= user.panPic.length === 1 ? '' : 'missing' %>"
            data-bs-toggle="modal" data-bs-target="#panPicModal">
            <div>
                <div class="t-label">PAN card</div>
                <div class="t-value"><%= user.panPic.length === 1 ? 'On file' : 'Upload required' %></div>
            </div>
            <span class="t-mark"><%= user.panPic.length === 1 ? '✓' : '!' %></span>
        </button>

        <button type="button" class="tile <%= user.userPic.length === 1 ? '' : 'missing' %>"
            data-bs-toggle="modal" data-bs-target="#userPicModal">
            <div>
                <div class="t-label">Face photo</div>
                <div class="t-value"><%= user.userPic.length === 1 ? 'On file' : 'Upload required' %></div>
            </div>
            <span class="t-mark"><%= user.userPic.length === 1 ? '✓' : '!' %></span>
        </button>

        <button type="button" class="tile <%= user.salarySlips.length > 0 ? '' : 'missing' %>"
            data-bs-toggle="modal" data-bs-target="#bankSlipsModal">
            <div>
                <div class="t-label">Salary slips</div>
                <div class="t-value">
                    <% if (user.salarySlips.length > 0) { %>
                        <%= user.salarySlips.length %> file<%= user.salarySlips.length === 1 ? '' : 's' %>
                    <% } else { %>
                        Upload required
                    <% } %>
                </div>
            </div>
            <span class="t-mark"><%= user.salarySlips.length > 0 ? '✓' : '!' %></span>
        </button>
    </div>
</section>

<!-- Identity form -->
<form action="/profile/update" method="POST" style="margin-bottom: 56px;">
    <div class="eyebrow" style="margin-bottom: 14px;">Identity</div>
    <div class="surface">
        <div class="field-row">
            <div class="field">
                <label class="label" for="name">Full name</label>
                <input type="text" id="name" name="name" value="<%= user.name %>" required>
            </div>
            <div class="field">
                <label class="label" for="email">Email</label>
                <input type="email" id="email" name="email" value="<%= user.email %>" readonly>
            </div>
        </div>

        <div class="field-row">
            <div class="field">
                <label class="label" for="aadharNumber">Aadhar number</label>
                <input type="text" id="aadharNumber" name="aadharNumber" maxlength="14"
                    pattern="[2-9]{1}[0-9]{3}\s{1}[0-9]{4}\s{1}[0-9]{4}$"
                    placeholder="XXXX XXXX XXXX"
                    title="Please enter your Aadhar number"
                    value="<%= user.aadharNumber !== 'undefined' ? user.aadharNumber : '' %>" required>
                <span class="help">12 digits, spaces auto-inserted.</span>
            </div>
            <div class="field">
                <label class="label" for="panNumber">PAN number</label>
                <input type="text" id="panNumber" name="panNumber" maxlength="10"
                    pattern="[A-Z]{5}[0-9]{4}[A-Z]{1}"
                    placeholder="AAAAA0000A"
                    title="Please enter your PAN number (capitals only)"
                    value="<%= user.panNumber !== 'undefined' ? user.panNumber : '' %>" required>
                <span class="help">Capitals only, format AAAAA0000A.</span>
            </div>
        </div>

        <div class="divider"></div>

        <div class="eyebrow" style="margin-bottom: 14px;">Banking</div>
        <div class="field-row">
            <div class="field">
                <label class="label" for="accountNumber">Account number</label>
                <input type="text" id="accountNumber" name="accountNumber" minlength="9" maxlength="18"
                    placeholder="Account number" title="Enter your bank account number"
                    value="<%= user.accountNumber !== undefined ? user.accountNumber : '' %>" required>
            </div>
            <div class="field">
                <label class="label" for="ifscCode">IFSC code</label>
                <input type="text" id="ifscCode" name="ifscCode"
                    pattern="[A-Za-z]{4}0[A-Z0-9a-z]{6}"
                    placeholder="ABCD0123456" title="Enter correct IFSC code"
                    value="<%= user.ifscCode !== undefined ? user.ifscCode : '' %>" required>
            </div>
        </div>

        <div class="field">
            <label class="label" for="ctc">Annual CTC (₹)</label>
            <input type="number" id="ctc" name="ctc" value="<%= user.ctc %>" required>
            <span class="help">
                Sets your eligibility tier. ≤ ₹2L → ceiling ₹10L. ≤ ₹10L → ceiling ₹50L. ≤ ₹25L → ceiling ₹1Cr. Above → ₹2.5Cr.
            </span>
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 12px; margin-top: 28px;">
            <a href="/profile" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary">
                Save changes
                <i class="fa-solid fa-arrow-right arrow" style="font-size: 11px;"></i>
            </button>
        </div>
    </div>
</form>

<!-- Modals -->
<div class="modal fade" id="aadharPicModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="aadharPicModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="aadharPicModalLabel">Upload Aadhar</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/profile/update/aadharpic" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="field">
                        <label class="label">Aadhar image</label>
                        <input type="file" name="image" required accept="image/*">
                        <span class="help">Clear photo of both sides preferred.</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="panPicModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="panPicModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="panPicModalLabel">Upload PAN</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/profile/update/panpic" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="field">
                        <label class="label">PAN image</label>
                        <input type="file" name="image" required accept="image/*">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="userPicModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="userPicModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userPicModalLabel">Upload face photo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/profile/update/userpic" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="field">
                        <label class="label">Profile photo</label>
                        <input type="file" name="image" required accept="image/*">
                        <span class="help">Clear, well-lit, recent.</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="bankSlipsModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="bankSlipsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="bankSlipsModalLabel">Upload salary slips</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/profile/update/bankslips" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="field">
                        <label class="label">Slips (last 3 months)</label>
                        <input type="file" name="image" multiple required accept="image/*,application/pdf">
                        <span class="help">Select multiple files at once.</span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">Upload</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        var input = document.getElementById("aadharNumber");
        if (!input) return;
        input.onkeydown = function () {
            if (input.value.length > 0) {
                if (input.value.length === 4 || input.value.length === 9) {
                    input.value += " ";
                }
            }
        };
    })();
</script>

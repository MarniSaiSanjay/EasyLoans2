<% layout('layout/boilerplate') %>

<style>
    .login-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 56px;
        align-items: center;
        padding: 24px 0;
    }

    @media (max-width: 860px) {
        .login-hero {
            grid-template-columns: 1fr;
            gap: 32px;
            padding: 16px 0;
        }
    }

    .login-hero h1 {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(40px, 5.2vw, 64px);
        line-height: 1;
        letter-spacing: -0.025em;
        color: var(--ink);
        margin: 0 0 16px;
    }

    .login-hero h1 .accented {
        color: var(--accent);
    }

    .login-hero .strapline {
        font-size: 16px;
        line-height: 1.55;
        color: var(--ink-soft);
        max-width: 48ch;
        margin: 0 0 24px;
        letter-spacing: -0.005em;
    }

    /* Right column visual: feature image grid */
    .feat-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .feat-card {
        background: var(--paper);
        border: 1px solid var(--rule);
        border-radius: var(--r-md);
        padding: 24px 22px 22px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 18px;
        animation: featIn 600ms ease both;
    }

    .feat-card:nth-child(1) { animation-delay: 0ms; }
    .feat-card:nth-child(2) { animation-delay: 80ms; }
    .feat-card:nth-child(3) { animation-delay: 160ms; }
    .feat-card:nth-child(4) { animation-delay: 240ms; }

    @keyframes featIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .feat-card img {
        width: 140px;
        height: 140px;
        object-fit: contain;
        display: block;
    }

    .feat-card .ft {
        font-size: 15px;
        font-weight: 600;
        color: var(--ink);
        line-height: 1.3;
        letter-spacing: -0.01em;
        margin: 0;
    }

    .feat-card .fd {
        font-size: 12.5px;
        color: var(--ink-faint);
        line-height: 1.45;
        margin: 0;
    }

    .signin-card {
        max-width: 460px;
    }
</style>

<section class="login-hero">
    <div>
        <div class="eyebrow eyebrow-accent" style="margin-bottom: 24px;">
            Peer-to-peer credit · no collateral · no queue
        </div>
        <h1>
            Borrow and lend, <span class="accented">human to human.</span>
        </h1>
        <p class="strapline">
            EasyLoans is a customer-to-customer marketplace for capital. Post what
            you need, browse what others have offered, negotiate the rate. Banks
            stay out of it.
        </p>

        <div class="signin-card stack">
            <a href="/auth/google" class="btn btn-primary btn-lg btn-block">
                <i class="fa-brands fa-google" style="font-size: 14px;"></i>
                Continue with Google
            </a>
            <p style="margin: 0; text-align: center; font-size: 13px; color: var(--ink-soft); letter-spacing: -0.005em;">
                Verified marketplace · KYC required after sign-in
            </p>
        </div>

    </div>

    <div class="feat-grid">
        <div class="feat-card">
            <img src="/stylesheets/repay.png" alt="">
            <div>
                <p class="ft">Flexible repayments</p>
                <p class="fd">Negotiate the schedule directly with your counterparty.</p>
            </div>
        </div>
        <div class="feat-card">
            <img src="/stylesheets/interest.png" alt="">
            <div>
                <p class="ft">Fair interest rates</p>
                <p class="fd">Counter-offer until both sides agree on the number.</p>
            </div>
        </div>
        <div class="feat-card">
            <img src="/stylesheets/assets.png" alt="">
            <div>
                <p class="ft">No collateral</p>
                <p class="fd">Eligibility from CTC and verified KYC — not assets.</p>
            </div>
        </div>
        <div class="feat-card">
            <img src="/stylesheets/userfriendly.png" alt="">
            <div>
                <p class="ft">User-friendly interface</p>
                <p class="fd">Two clicks to post, instant matches, no bank queue.</p>
            </div>
        </div>
    </div>
</section>

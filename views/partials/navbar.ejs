<header class="topbar">
    <div class="topbar-inner">
        <a href="/home" class="brand">
            <span class="word">EasyLoans</span>
        </a>

        <button class="nav-toggle" type="button" aria-label="Toggle navigation" data-nav-toggle>
            <i class="fa-solid fa-bars"></i>
        </button>

        <ul class="nav-links" data-nav-menu>
            <% if (currentUser !== undefined) { %>
                <li><a href="/home" class="nav-link">Browse</a></li>
                <li><a href="/home?isPending=true" class="nav-link">My deals</a></li>
                <li><a href="/home?isPending=false" class="nav-link">Closed</a></li>
            <% } %>
        </ul>

        <ul class="nav-links right">
            <li><a href="/about" class="nav-link">About</a></li>
            <% if (currentUser !== undefined) { %>
                <li>
                    <a href="/loan/apply" class="btn btn-accent btn-sm">
                        Post a deal
                        <i class="fa-solid fa-arrow-right arrow" style="font-size: 11px;"></i>
                    </a>
                </li>
                <li>
                    <a href="/profile" class="nav-link" aria-label="Profile" style="padding:0;">
                        <% if (currentUser.profilePicUrl) { %>
                            <img src="<%= currentUser.profilePicUrl %>" alt="" class="nav-avatar">
                        <% } else { %>
                            <span class="nav-avatar" style="display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;background:var(--paper-tint);">
                                <%= (currentUser.name || 'U').charAt(0).toUpperCase() %>
                            </span>
                        <% } %>
                    </a>
                </li>
                <li>
                    <a href="/auth/logout" class="nav-icon-btn" aria-label="Sign out">
                        <i class="fa-solid fa-arrow-right-from-bracket" style="font-size: 12px;"></i>
                    </a>
                </li>
            <% } else { %>
                <li><a href="/auth/login" class="btn btn-primary btn-sm">Sign in</a></li>
            <% } %>
        </ul>
    </div>
</header>

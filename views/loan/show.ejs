<% layout('layout/boilerplate') %>

<%
    function fmtINR(n) {
        if (n === undefined || n === null) return '—';
        return Number(n).toLocaleString('en-IN');
    }
    function initials(name) {
        if (!name) return '?';
        var parts = String(name).trim().split(/\s+/);
        if (parts.length === 1) return parts[0].slice(0, 2).toUpperCase();
        return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
    }
    var isOwner = currentUser.id === loan.owner.id;
%>

<div class="header-block" style="padding-bottom: 16px;">
    <div>
        <a href="/home" class="bare faint" style="font-size: 13px; display: inline-flex; align-items: center; gap: 6px; margin-bottom: 12px;">
            <i class="fa-solid fa-arrow-left" style="font-size: 11px;"></i>
            All deals
        </a>
        <div class="eyebrow eyebrow-accent" style="margin-bottom: 6px;">Deal record</div>
        <h1 class="h-title">
            <%= loan.category === 'provide' ? 'Capital offered' : 'Capital requested' %> by <%= loan.owner.name %>
        </h1>
    </div>
    <div class="row-flex">
        <% if (loan.category === 'provide') { %>
            <span class="pill accent"><span class="pill-dot"></span>Offering</span>
        <% } else { %>
            <span class="pill info"><span class="pill-dot"></span>Requesting</span>
        <% } %>
        <% if (loan.isPending) { %>
            <span class="pill warn"><span class="pill-dot"></span>Open</span>
        <% } else { %>
            <span class="pill"><span class="pill-dot"></span>Closed</span>
        <% } %>
    </div>
</div>

<!-- Hero principal -->
<section class="hero-stat" style="border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); margin-bottom: 40px;">
    <div>
        <div class="eyebrow" style="margin-bottom: 14px;">Principal</div>
        <div class="amount"><span class="rupee">₹</span><%= fmtINR(loan.amount) %></div>
    </div>
    <div class="side">
        <div class="meta">
            <div class="eyebrow" style="margin-bottom: 6px;">Interest</div>
            <div class="v"><%= loan.interest %>%</div>
        </div>
        <div class="meta">
            <div class="eyebrow" style="margin-bottom: 6px;">Tenure</div>
            <div class="v"><%= loan.timePeriod %> yr</div>
        </div>
    </div>
</section>

<!-- Counterparty / owner card -->
<section style="margin-bottom: 40px;">
    <div class="eyebrow" style="margin-bottom: 14px;"><%= isOwner ? 'Your post' : 'Posted by' %></div>
    <div class="surface" style="display: flex; align-items: center; gap: 18px;">
        <span style="width: 52px; height: 52px; border-radius: 50%; background: var(--paper-tint); border: 1px solid var(--rule-strong); display: inline-flex; align-items: center; justify-content: center; font-family: var(--serif); font-style: italic; font-size: 22px;">
            <%= initials(loan.owner.name) %>
        </span>
        <div>
            <div style="font-size: 17px; font-weight: 500;"><%= loan.owner.name %></div>
            <div class="faint mono" style="font-size: 13px; margin-top: 2px;"><%= loan.owner.email %></div>
        </div>
    </div>
</section>

<% if (!isOwner && loan.isPending) { %>
    <!-- Counter-offer form -->
    <section style="margin-bottom: 40px;">
        <div class="header-block" style="padding-bottom: 14px;">
            <div>
                <div class="eyebrow" style="margin-bottom: 6px;">Negotiate</div>
                <h2 class="h-section">Propose different terms</h2>
                <p class="muted" style="margin-top: 6px; max-width: 56ch; font-size: 14px;">
                    Send a counter-offer with your preferred interest and tenure. <%= loan.owner.name.split(' ')[0] %> can accept or reject it.
                </p>
            </div>
            <button type="button" class="btn btn-ghost" data-bs-toggle="modal" data-bs-target="#counterModal">
                Counter-offer
            </button>
        </div>
    </section>

    <!-- Counter modal -->
    <div class="modal fade" id="counterModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Counter-offer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/loan/<%= loan.id %>/counter" method="post">
                    <div class="modal-body">
                        <div class="field-row">
                            <div class="field">
                                <label class="label" for="c-interest">Interest (%)</label>
                                <input type="number" id="c-interest" name="interest" step="0.01" min="0" max="30" placeholder="e.g. 10.5" required>
                            </div>
                            <div class="field">
                                <label class="label" for="c-period">Tenure (years)</label>
                                <input type="number" id="c-period" name="timePeriod" step="0.1" min="0.1" max="50" placeholder="e.g. 3" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-ghost" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary" data-bs-dismiss="modal">Send counter</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
<% } %>

<% if (isOwner && loan.isPending) { %>
    <!-- Counters received -->
    <section>
        <div class="header-block" style="padding-bottom: 14px;">
            <div>
                <div class="eyebrow" style="margin-bottom: 6px;">Inbox</div>
                <h2 class="h-section">Counter-offers received</h2>
                <p class="muted" style="margin-top: 6px; max-width: 56ch; font-size: 14px;">
                    Each entry is a different counter-party proposing their own rate and tenure. Accepting one closes the deal.
                </p>
            </div>
            <div class="pill"><span class="pill-dot"></span><%= loan.counters.length %> received</div>
        </div>

        <% if (loan.counters.length === 0) { %>
            <div class="empty">
                <div class="glyph">…</div>
                <h2>No counter-offers yet</h2>
                <p>When someone proposes terms, you'll see them listed here with accept and reject controls.</p>
            </div>
        <% } else { %>
            <section class="loan-list">
                <% for (let c of loan.counters) { %>
                    <div class="loan-row" style="grid-template-columns: minmax(0, 1.4fr) minmax(0, 0.8fr) minmax(0, 0.8fr) auto;">
                        <div class="col col-amount">
                            <span class="label">From</span>
                            <div class="who">
                                <span class="avatar"><%= initials(c.owner.name) %></span>
                                <span class="value"><%= c.owner.name %></span>
                            </div>
                        </div>
                        <div class="col">
                            <span class="label">Interest</span>
                            <span class="value mono"><%= c.interest %>%</span>
                        </div>
                        <div class="col">
                            <span class="label">Tenure</span>
                            <span class="value mono"><%= c.timePeriod %> yr</span>
                        </div>
                        <div class="actions">
                            <a href="/loan/<%= loan.id %>/counter/<%= c.id %>/reject" class="btn btn-danger btn-sm">
                                Reject
                            </a>
                            <a href="/loan/<%= loan.id %>/counter/<%= c.id %>/accept" class="btn btn-primary btn-sm">
                                Accept
                                <i class="fa-solid fa-check arrow" style="font-size: 10px;"></i>
                            </a>
                        </div>
                    </div>
                <% } %>
            </section>
        <% } %>
    </section>
<% } %>

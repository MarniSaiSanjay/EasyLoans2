<% layout('layout/boilerplate') %>

<div class="header-block">
    <div>
        <div class="eyebrow eyebrow-accent" style="margin-bottom: 6px;">Edit deal</div>
        <h1 class="h-title">Update terms</h1>
        <p class="lede" style="margin-top: 8px;">
            Change the principal, rate or tenure. Existing counter-offers will still apply.
        </p>
    </div>
    <a href="/home" class="btn btn-ghost">
        <i class="fa-solid fa-arrow-left" style="font-size: 11px;"></i>
        Cancel
    </a>
</div>

<form action="/loan/<%= loan.id %>/edit?_method=PUT" method="post" style="margin-top: 24px;">
    <div class="surface">
        <div class="field">
            <label class="label" for="amount">Amount (₹)</label>
            <input type="number" id="amount" name="amount" value="<%= loan.amount %>" min="1" max="100000000" required>
        </div>

        <div class="field-row">
            <div class="field">
                <label class="label" for="interest">Interest rate (%)</label>
                <input type="number" id="interest" name="interest" step="0.01" min="0" max="30" value="<%= loan.interest %>" required>
            </div>
            <div class="field">
                <label class="label" for="timePeriod">Tenure (years)</label>
                <input type="number" id="timePeriod" name="timePeriod" step="0.1" min="0.1" max="50" value="<%= loan.timePeriod %>" required>
            </div>
        </div>

        <div class="field">
            <label class="label" for="category">Category</label>
            <select name="category" id="category">
                <option value="provide" <%= loan.category === 'provide' ? 'selected' : '' %>>Offering capital (lender)</option>
                <option value="request" <%= loan.category === 'request' ? 'selected' : '' %>>Requesting capital (borrower)</option>
            </select>
        </div>

        <div class="divider"></div>

        <div style="display: flex; justify-content: flex-end; gap: 12px;">
            <a href="/home" class="btn btn-ghost">Cancel</a>
            <button type="submit" class="btn btn-primary">
                Save changes
                <i class="fa-solid fa-arrow-right arrow" style="font-size: 11px;"></i>
            </button>
        </div>
    </div>
</form>

<% layout('layout/boilerplate') %>

<style>
    .about-hero {
        padding: 32px 0 56px;
        border-bottom: 1px solid var(--rule);
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
        gap: 56px;
        align-items: center;
    }

    @media (max-width: 860px) {
        .about-hero {
            grid-template-columns: 1fr;
            gap: 32px;
        }
    }

    .about-hero h1 {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(48px, 8vw, 96px);
        line-height: 0.95;
        letter-spacing: -0.025em;
        margin: 0 0 24px;
        max-width: 14ch;
    }

    .about-hero h1 .accent {
        color: var(--accent);
    }

    .about-hero p.lede {
        font-size: 18px;
        max-width: 56ch;
    }

    .about-hero img {
        width: 100%;
        height: auto;
        max-height: 380px;
        object-fit: contain;
    }

    .feature-block {
        padding: 56px 0;
        border-bottom: 1px solid var(--rule);
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.4fr);
        gap: 48px;
        align-items: start;
    }

    @media (max-width: 860px) {
        .feature-block {
            grid-template-columns: 1fr;
            gap: 32px;
            padding: 40px 0;
        }
    }

    .feature-side {
        position: sticky;
        top: 100px;
    }

    .feature-side img {
        width: 100%;
        height: auto;
        max-height: 320px;
        object-fit: contain;
        margin-top: 24px;
    }

    .feature-list {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 28px 32px;
    }

    @media (max-width: 640px) {
        .feature-list {
            grid-template-columns: 1fr;
        }
    }

    .feature-item {
        display: flex;
        flex-direction: column;
        gap: 8px;
        border-top: 1px solid var(--ink);
        padding-top: 14px;
    }

    .feature-item h3 {
        font-size: 17px;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin: 0;
    }

    .feature-item p {
        margin: 0;
        font-size: 14px;
        color: var(--ink-soft);
        line-height: 1.5;
    }

    .feature-item .idx {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--ink-faint);
        letter-spacing: 0.06em;
    }

    .how-block {
        padding: 56px 0;
        border-bottom: 1px solid var(--rule);
    }

    .steps {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        margin-top: 28px;
    }

    @media (max-width: 860px) {
        .steps { grid-template-columns: 1fr; }
    }

    .step {
        padding: 28px 28px 28px 0;
        border-right: 1px solid var(--rule);
    }

    .step:last-child { border-right: 0; }

    @media (max-width: 860px) {
        .step {
            padding: 24px 0;
            border-right: 0;
            border-bottom: 1px solid var(--rule);
        }
        .step:last-child { border-bottom: 0; }
    }

    .step .num {
        font-family: var(--serif);
        font-style: italic;
        font-size: 64px;
        color: var(--accent);
        line-height: 1;
        margin-bottom: 12px;
    }

    .step h3 {
        font-size: 18px;
        font-weight: 600;
        margin: 0 0 6px;
        letter-spacing: -0.01em;
    }

    .step p {
        margin: 0;
        color: var(--ink-soft);
        font-size: 14px;
        line-height: 1.5;
    }

    .contact-block {
        padding: 64px 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 56px;
        align-items: center;
        border-bottom: 1px solid var(--rule);
    }

    @media (max-width: 860px) {
        .contact-block {
            grid-template-columns: 1fr;
            gap: 32px;
        }
    }

    .contact-block img {
        width: 100%;
        height: auto;
        max-height: 320px;
        object-fit: contain;
    }

    .contact-block h2 {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(40px, 6vw, 64px);
        line-height: 1;
        letter-spacing: -0.02em;
        margin: 0 0 16px;
    }
</style>

<section class="about-hero">
    <div>
        <div class="eyebrow eyebrow-accent" style="margin-bottom: 24px;">About</div>
        <h1>
            A marketplace<br>for <span class="accent">private credit.</span>
        </h1>
        <p class="lede">
            EasyLoans is a customer-to-customer platform for debt. Users finance
            each other or request capital, and either side can propose adjustments
            to the rate and tenure. The owner accepts or rejects. Banks never enter
            the loop.
        </p>
    </div>
    <div>
        <img src="/stylesheets/abt.png" alt="About EasyLoans">
    </div>
</section>

<section class="feature-block">
    <div class="feature-side">
        <div class="eyebrow" style="margin-bottom: 14px;">What you get</div>
        <h2 class="h-title">Designed around the two sides of a deal.</h2>
        <p class="muted" style="margin-top: 12px; max-width: 36ch;">
            Every feature works the same whether you're the lender or the borrower.
        </p>
        <img src="/stylesheets/features.png" alt="">
    </div>

    <div class="feature-list">
        <div class="feature-item">
            <span class="idx">01 / Flexibility</span>
            <h3>Flexible repayments</h3>
            <p>Negotiate the schedule directly with your counterparty. No fixed product.</p>
        </div>
        <div class="feature-item">
            <span class="idx">02 / Pricing</span>
            <h3>Fair, transparent rates</h3>
            <p>Counter-offer until both sides agree. The number you see is the number you sign.</p>
        </div>
        <div class="feature-item">
            <span class="idx">03 / Access</span>
            <h3>No collateral</h3>
            <p>Eligibility is derived from CTC and verified identity, not assets you don't have.</p>
        </div>
        <div class="feature-item">
            <span class="idx">04 / Speed</span>
            <h3>No bank queue</h3>
            <p>Two clicks to post, instant matches, no waiting on a branch officer.</p>
        </div>
        <div class="feature-item">
            <span class="idx">05 / KYC</span>
            <h3>Real-person verification</h3>
            <p>Aadhar, PAN, salary slips and a face photo. Required before either side can transact.</p>
        </div>
        <div class="feature-item">
            <span class="idx">06 / Reach</span>
            <h3>Mobile-first</h3>
            <p>The whole flow works on a phone — no app needed.</p>
        </div>
    </div>
</section>

<section class="how-block">
    <div class="eyebrow" style="margin-bottom: 6px;">How it works</div>
    <h2 class="h-title">Three steps to a closed deal.</h2>
    <div class="steps">
        <div class="step">
            <div class="num">i.</div>
            <h3>Verify yourself</h3>
            <p>Upload your KYC documents. We compute a CIBIL-equivalent score and your eligibility ceiling.</p>
        </div>
        <div class="step">
            <div class="num">ii.</div>
            <h3>Post or browse</h3>
            <p>Post the amount, interest and tenure you want — or browse what other verified users have offered.</p>
        </div>
        <div class="step">
            <div class="num">iii.</div>
            <h3>Counter and close</h3>
            <p>Negotiate via counter-offers. Once both sides agree, the deal is locked and emailed to both parties.</p>
        </div>
    </div>
</section>

<section class="contact-block">
    <div>
        <img src="/stylesheets/contactus.png" alt="">
    </div>
    <div>
        <div class="eyebrow eyebrow-accent" style="margin-bottom: 16px;">Contact</div>
        <h2>Have questions?</h2>
        <p class="muted" style="margin: 0 0 24px; max-width: 40ch;">
            Drop us a line and we'll get back to you. We read every message.
        </p>

        <form action="https://formsubmit.co/el/hilolu" method="POST" class="stack" id="contactForm">
            <div class="field-row">
                <div class="field" style="margin: 0;">
                    <label class="label" for="c-name">Name</label>
                    <input type="text" id="c-name" name="name" required>
                </div>
                <div class="field" style="margin: 0;">
                    <label class="label" for="c-email">Email</label>
                    <input type="email" id="c-email" name="email" required>
                </div>
            </div>

            <div class="field" style="margin: 0;">
                <label class="label" for="c-phone">Mobile number</label>
                <input type="tel" id="c-phone" name="phone">
            </div>

            <div class="field" style="margin: 0;">
                <label class="label" for="c-msg">Message</label>
                <textarea id="c-msg" name="message" rows="4" required></textarea>
            </div>

            <div style="display: flex; justify-content: flex-end;">
                <button type="submit" class="btn btn-primary">
                    Send message
                    <i class="fa-solid fa-arrow-right arrow" style="font-size: 11px;"></i>
                </button>
            </div>
        </form>
    </div>
</section>

<section style="padding: 64px 0 32px; text-align: center;">
    <h2 class="h-display md" style="margin: 0 0 24px;">Ready when you are.</h2>
    <a href="/auth/google" class="btn btn-primary btn-lg">
        Continue with Google
        <i class="fa-solid fa-arrow-right arrow" style="font-size: 12px;"></i>
    </a>
</section>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#f5f1e8">

    <title>EasyLoans — Peer-to-peer credit</title>

    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
        integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
        crossorigin="anonymous">

    <link rel="stylesheet" href="/stylesheets/app.css">

    <script src="https://kit.fontawesome.com/26a692bc87.js" crossorigin="anonymous"></script>
</head>

<body>
    <%- include('../partials/navbar') %>

    <main class="shell">
        <%- include('../partials/flash') %>
        <%- body %>
    </main>

    <footer class="foot">
        <div class="foot-inner">
            <div>
                <span class="wordmark">EasyLoans</span>
                <span style="margin-left: 10px;">© <%= new Date().getFullYear() %></span>
            </div>
            <div>
                Peer-to-peer credit, without the queue.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
        crossorigin="anonymous"></script>

    <script>
        // Mobile nav toggle
        (function () {
            var toggle = document.querySelector('[data-nav-toggle]');
            var menu = document.querySelector('[data-nav-menu]');
            if (!toggle || !menu) return;
            toggle.addEventListener('click', function () {
                menu.classList.toggle('open');
            });
        })();

        // Auto-dismiss flash after 6s
        setTimeout(function () {
            document.querySelectorAll('.flash[data-dismiss-auto]').forEach(function (f) {
                f.style.transition = 'opacity 400ms ease';
                f.style.opacity = '0';
                setTimeout(function () { f.remove(); }, 420);
            });
        }, 6000);
    </script>
</body>

</html>
